terraform/override.tf.json

# ============================================================
# Scan outputs — generated at runtime, never committed
# Prevents Gitleaks false positives on CVE data in JSON files
# ============================================================
gitleaks-report.json
semgrep-report.json
semgrep.sarif
trivy-fs-report.json
trivy-image-report.json
trivy-fs.sarif
trivy-image.sarif
evaluation/*.json
evaluation/*.sarif

# ============================================================
# Generated dashboards — built by pipeline at runtime
# ============================================================
dashboard/
generic-dashboard/

# ============================================================
# Database
# flask-webgoat uses SQLite
# ============================================================
*.db
*.sqlite
*.sqlite3

# ============================================================
# Secrets and environment variables
# Safety net — should never be committed
# ============================================================
.env
.env.*
*.env

# Logs
*.log

